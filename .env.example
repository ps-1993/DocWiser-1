PORT=3000
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=26214400

ORACLE_USER=system
ORACLE_PASSWORD=oracle
ORACLE_CONNECT_STRING=localhost:1522/FREEPDB1
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=5
ORACLE_POOL_INCREMENT=1

# Use local Ollama by default.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional OpenAI settings if you switch providers later.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# This example uses llama3.1 for both chat and embeddings.
EMBEDDING_MODEL=llama3.1
CHAT_MODEL=llama3.1
EMBEDDING_DIMENSION=4096
CHAT_TEMPERATURE=0.2

CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=4
MAX_CONTEXT_CHARS=12000

# RAG document storage/search now uses OCI Vector Store instead of Oracle VECTOR columns.
DOCUMENT_STORE_PROVIDER=oci-vector-store
OCI_REGION=us-ashburn-1
OCI_GENERATIVE_AI_BASE_URL=https://inference.generativeai.us-ashburn-1.oci.oraclecloud.com/openai/v1
